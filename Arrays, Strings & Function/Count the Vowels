Qstn : You're given a string str your job is to count the number of vowels present in the given string. The vowels can be either uppercase or lowercase.
Ans (in c++):
#include <bits/stdc++.h>
using namespace std;

class solution {
public:
    int countVowels(string str) {
        //Write your code here...
        int result=0;
        int n= str.length();
        char arr [] = {'a', 'e', 'i' , 'o', 'u', 'A', 'E', 'I', 'O' , 'U'};
        for (int i=0; i<10; i++){
            for (int j=0; j<str.length();j++){
                 if (arr[i] == str.at(j)){
                result ++;
                }
            }
        }
       return result; 
    }
};

Here to improve the TC from O(n^2) to O(n) we can do like this;

#include <bits/stdc++.h>
using namespace std;

class solution {
public:
    int countVowels(string str) {
        //Write your code here...
        int result=0;
        int n= str.length();
        for (int i=0; i<n; i++){
           if (str.at(i) == 'a' || str.at(i) == 'e' || str.at(i) == 'i' || str.at(i) == 'o' ||
           str.at(i) == 'u' || str.at(i) == 'A' || str.at(i) == 'E' || str.at(i) == 'I' ||
           str.at(i) == 'O' || str.at(i) == 'U') {
               result ++;
           }
        }
       return result; 
    }
};

