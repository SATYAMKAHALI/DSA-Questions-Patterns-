Qstn : You are given two numbers and an operator.Based on the operator symbol (+, -, *, /), you perform the corresponding arithmetic operation. Then print the result.
Input : a = 10, b = 5, op= "+"  , Output = 15 
Ans : (in C++) 
#include <bits/stdc++.h>
using namespace std;

void performOperation(long a, long b, char op){
    int result;
    if(op=='/' ){
        result = a/b;
    }
    else if (op=='+'){
        result = a+b;
    }
    else if (op=='-'){
        result = a-b;
    }
    else if (op=='*'){
        result = a*b;
    }
    cout<<result<<endl;
}
int main() {
    // Write Your Code here...
    long a,b;
    char op;
    cin>>a>>b>>op;
    performOperation(a , b , op);
    return 0;
}

